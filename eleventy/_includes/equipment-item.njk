{% extends "layout.njk" %}
{% set catObj = categories | findCat(category) %}

{% block content %}
<section style="max-width:1100px;margin:0 auto;padding:52px 24px 88px;">

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a><span class="sep">/</span>
    <a href="/equipment/">Equipment</a><span class="sep">/</span>
    <a href="/equipment/{{ category }}/">{{ catObj.name }}</a><span class="sep">/</span>
    <span class="cur">{{ name }}</span>
  </nav>

  <!-- Item detail -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:start;" class="item-detail-grid">

    <!-- Photo -->
    <div style="border-radius:18px;overflow:hidden;border:1px solid rgba(255,255,255,.1);">
      {% if image %}
      <img src="{{ image }}" alt="{{ name }}" style="width:100%;aspect-ratio:4/3;object-fit:cover;">
      {% else %}
      <div style="width:100%;aspect-ratio:4/3;background:repeating-linear-gradient(135deg,#191a1d,#191a1d 11px,#141417 11px,#141417 22px);display:flex;align-items:center;justify-content:center;">
        <span style="color:#6f6f76;font-size:13px;letter-spacing:.08em;">[ photo ]</span>
      </div>
      {% endif %}
    </div>

    <!-- Info -->
    <div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px;">
        <span style="font-size:12px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:#ff5a1f;border:1px solid rgba(255,90,31,.4);padding:5px 11px;border-radius:999px;background:rgba(255,90,31,.09);">{{ subcategory }}</span>
        <span style="font-size:12px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:#9b9ba2;border:1px solid rgba(255,255,255,.12);padding:5px 11px;border-radius:999px;">{{ tag }}</span>
      </div>
      <h1 style="font-family:'Sora',sans-serif;font-weight:800;font-size:clamp(26px,3.5vw,40px);letter-spacing:-.02em;margin:0 0 18px;line-height:1.1;">{{ name }}</h1>
      {% if description %}
      <p style="color:#b3b3ba;font-size:16px;line-height:1.65;margin:0 0 28px;">{{ description }}</p>
      {% endif %}
      <div style="display:flex;flex-direction:column;gap:12px;">
        <a href="/#contact" class="btn btn-accent" style="padding:15px 24px;font-size:15px;text-align:center;">Request rental →</a>
        <a href="/equipment/{{ category }}/" class="btn btn-outline" style="padding:13px 24px;font-size:14px;font-weight:600;text-align:center;">← Back to {{ catObj.name }}</a>
      </div>
    </div>
  </div>

  <!-- Markdown body (extra specs/notes from CMS) -->
  {% if content %}
  <div style="margin-top:52px;padding-top:40px;border-top:1px solid rgba(255,255,255,.08);">
    <h2 style="font-family:'Sora',sans-serif;font-weight:700;font-size:22px;margin:0 0 18px;">Details &amp; specifications</h2>
    <div style="color:#b3b3ba;font-size:15px;line-height:1.7;max-width:720px;">
      {{ content | safe }}
    </div>
  </div>
  {% endif %}

  <!-- Related items (same subcategory) -->
  {% set related = collections.equipment | bySub(subcategory) %}
  {% if related.length > 1 %}
  <div style="margin-top:64px;">
    <h2 style="font-family:'Sora',sans-serif;font-weight:700;font-size:22px;margin:0 0 24px;">More {{ subcategory }}</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;">
      {% for rel in related %}
      {% if rel.url != page.url %}
      <a href="{{ rel.url }}" class="item-card">
        {% if rel.data.image %}
        <img src="{{ rel.data.image }}" alt="{{ rel.data.name }}" style="aspect-ratio:4/3;object-fit:cover;width:100%;">
        {% else %}
        <div style="aspect-ratio:4/3;background:repeating-linear-gradient(135deg,#191a1d,#191a1d 11px,#141417 11px,#141417 22px);display:flex;align-items:center;justify-content:center;">
          <span style="color:#6f6f76;font-size:11px;">[ photo ]</span>
        </div>
        {% endif %}
        <div style="padding:14px 16px;flex:1;display:flex;flex-direction:column;gap:4px;">
          <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:15px;margin:0;">{{ rel.data.name }}</h3>
          <span style="color:#9b9ba2;font-size:12px;">{{ rel.data.tag }}</span>
          <span style="margin-top:8px;color:#ff5a1f;font-size:12px;font-weight:600;font-family:'Sora',sans-serif;">View →</span>
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
  {% endif %}

</section>
{% endblock %}
