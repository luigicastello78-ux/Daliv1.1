---
pageTitle: Sound & Instrument Rental
---
{% extends "layout.njk" %}
{% block content %}

<!-- Hero -->
<section id="top" style="position:relative;overflow:hidden;border-bottom:1px solid rgba(255,255,255,.06);">
  <div style="position:absolute;inset:0;background:radial-gradient(70% 60% at 72% -5%,rgba(255,90,31,.22) 0%,transparent 58%);pointer-events:none;"></div>
  <div style="max-width:1200px;margin:0 auto;padding:78px 24px 66px;display:grid;grid-template-columns:1.08fr .92fr;gap:48px;align-items:center;position:relative;" class="hero-grid">
    <div>
      <span style="display:inline-block;font-size:12px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:#ff5a1f;border:1px solid rgba(255,90,31,.4);padding:6px 13px;border-radius:999px;background:rgba(255,90,31,.09);">Sound &amp; instrument rental</span>
      <h1 style="font-family:'Sora',sans-serif;font-weight:800;font-size:clamp(36px,5.2vw,64px);line-height:1.03;letter-spacing:-.025em;margin:20px 0 18px;">Gear that makes your event sound unforgettable</h1>
      <p style="color:#b3b3ba;font-size:clamp(16px,1.5vw,19px);line-height:1.6;max-width:560px;">From RCF line arrays to keyboards, drums and microphones — rent professional stage equipment with delivery, setup and on-site support.</p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:30px;">
        <a href="#contact" class="btn btn-accent" style="padding:15px 24px;font-size:15px;">Get a free quote</a>
        <a href="/equipment/" class="btn btn-outline" style="padding:15px 24px;font-size:15px;">Browse equipment</a>
      </div>
      <div style="display:flex;gap:40px;margin-top:46px;flex-wrap:wrap;">
        <div>
          <div style="font-family:'Sora',sans-serif;font-weight:800;font-size:30px;color:#fff;">1,200+</div>
          <div style="color:#8f8f96;font-size:13px;margin-top:3px;">Events powered</div>
        </div>
        <div>
          <div style="font-family:'Sora',sans-serif;font-weight:800;font-size:30px;color:#fff;">500+</div>
          <div style="color:#8f8f96;font-size:13px;margin-top:3px;">Pieces of gear</div>
        </div>
        <div>
          <div style="font-family:'Sora',sans-serif;font-weight:800;font-size:30px;color:#fff;">12</div>
          <div style="color:#8f8f96;font-size:13px;margin-top:3px;">Years on stage</div>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div style="position:absolute;inset:0;background:radial-gradient(80% 50% at 50% 100%,rgba(255,90,31,.3),transparent 70%);"></div>
      <div style="position:absolute;inset:0;display:flex;align-items:flex-end;justify-content:center;gap:5px;padding:28px 26px;">
        <div class="eq-bar" style="--dur:1.00s;--delay:0.00s;"></div>
        <div class="eq-bar" style="--dur:1.22s;--delay:0.07s;"></div>
        <div class="eq-bar" style="--dur:1.44s;--delay:0.14s;"></div>
        <div class="eq-bar" style="--dur:1.66s;--delay:0.21s;"></div>
        <div class="eq-bar" style="--dur:1.88s;--delay:0.28s;"></div>
        <div class="eq-bar" style="--dur:1.00s;--delay:0.35s;"></div>
        <div class="eq-bar" style="--dur:1.22s;--delay:0.42s;"></div>
        <div class="eq-bar" style="--dur:1.44s;--delay:0.49s;"></div>
        <div class="eq-bar" style="--dur:1.66s;--delay:0.56s;"></div>
        <div class="eq-bar" style="--dur:1.88s;--delay:0.63s;"></div>
        <div class="eq-bar" style="--dur:1.00s;--delay:0.70s;"></div>
        <div class="eq-bar" style="--dur:1.22s;--delay:0.77s;"></div>
        <div class="eq-bar" style="--dur:1.44s;--delay:0.84s;"></div>
        <div class="eq-bar" style="--dur:1.66s;--delay:0.91s;"></div>
        <div class="eq-bar" style="--dur:1.88s;--delay:0.98s;"></div>
        <div class="eq-bar" style="--dur:1.00s;--delay:1.05s;"></div>
        <div class="eq-bar" style="--dur:1.22s;--delay:1.12s;"></div>
        <div class="eq-bar" style="--dur:1.44s;--delay:1.19s;"></div>
        <div class="eq-bar" style="--dur:1.66s;--delay:1.26s;"></div>
        <div class="eq-bar" style="--dur:1.88s;--delay:1.33s;"></div>
        <div class="eq-bar" style="--dur:1.00s;--delay:1.40s;"></div>
        <div class="eq-bar" style="--dur:1.22s;--delay:1.47s;"></div>
      </div>
      <span style="position:absolute;top:14px;left:14px;font-size:11px;letter-spacing:.08em;color:#7a7a80;background:rgba(0,0,0,.45);padding:5px 9px;border-radius:7px;">[ stage photo ]</span>
    </div>
  </div>
</section>

<!-- Equipment categories -->
<section id="equipment" style="padding:88px 0;">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;gap:24px;margin-bottom:42px;flex-wrap:wrap;">
      <h2 style="font-family:'Sora',sans-serif;font-weight:800;font-size:clamp(28px,3.4vw,42px);letter-spacing:-.02em;margin:0;max-width:520px;">Everything you need on stage</h2>
      <p style="color:#9b9ba2;max-width:360px;margin:0;font-size:15px;line-height:1.55;">Rent a single piece or a complete setup for any event.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(264px,1fr));gap:18px;">
      {% for cat in categories %}
      {% set count = collections.equipment | catCount(cat.id) %}
      <a href="/equipment/{{ cat.id }}/" class="eq-card">
        <div style="position:relative;aspect-ratio:16/10;background:repeating-linear-gradient(135deg,#191a1d,#191a1d 11px,#141417 11px,#141417 22px);">
          <span style="position:absolute;bottom:10px;left:12px;font-size:11px;letter-spacing:.08em;color:#6f6f76;background:rgba(0,0,0,.4);padding:4px 8px;border-radius:6px;">[ photo ]</span>
          <span style="position:absolute;top:10px;right:12px;font-family:'Sora',sans-serif;font-weight:700;font-size:13px;color:#ff5a1f;">{{ loop.index | pad2 }}</span>
        </div>
        <div style="padding:18px;">
          <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:18px;margin:0 0 7px;">{{ cat.name }}</h3>
          <p style="color:#9b9ba2;font-size:14px;line-height:1.5;margin:0 0 13px;">{{ cat.desc }}</p>
          <span style="color:#ff5a1f;font-size:13px;font-weight:600;font-family:'Sora',sans-serif;">{{ count }} models →</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- How it works -->
<section id="how" class="section-alt" style="padding:88px 0;">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <div style="margin-bottom:46px;max-width:620px;">
      <h2 style="font-family:'Sora',sans-serif;font-weight:800;font-size:clamp(28px,3.4vw,42px);letter-spacing:-.02em;margin:0 0 12px;">Renting is simple</h2>
      <p style="color:#9b9ba2;margin:0;font-size:15px;line-height:1.55;">Perfect sound in four steps.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:22px;" class="step-grid">
      <div>
        <div style="font-family:'Sora',sans-serif;font-weight:800;font-size:38px;color:#ff5a1f;line-height:1;">01</div>
        <div class="step-line"></div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:18px;margin:0 0 8px;">Tell us about your event</h3>
        <p style="color:#9b9ba2;font-size:14px;line-height:1.55;margin:0;">Share the date, venue and what you are planning.</p>
      </div>
      <div>
        <div style="font-family:'Sora',sans-serif;font-weight:800;font-size:38px;color:#ff5a1f;line-height:1;">02</div>
        <div class="step-line"></div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:18px;margin:0 0 8px;">Get a tailored quote</h3>
        <p style="color:#9b9ba2;font-size:14px;line-height:1.55;margin:0;">We recommend the right gear and send a clear price.</p>
      </div>
      <div>
        <div style="font-family:'Sora',sans-serif;font-weight:800;font-size:38px;color:#ff5a1f;line-height:1;">03</div>
        <div class="step-line"></div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:18px;margin:0 0 8px;">We deliver &amp; set up</h3>
        <p style="color:#9b9ba2;font-size:14px;line-height:1.55;margin:0;">Our crew installs, tunes and tests everything on site.</p>
      </div>
      <div>
        <div style="font-family:'Sora',sans-serif;font-weight:800;font-size:38px;color:#ff5a1f;line-height:1;">04</div>
        <div class="step-line"></div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:18px;margin:0 0 8px;">Enjoy the show</h3>
        <p style="color:#9b9ba2;font-size:14px;line-height:1.55;margin:0;">We stay on standby and pack down when you are done.</p>
      </div>
    </div>
  </div>
</section>

<!-- Packages -->
<section id="packages" style="padding:88px 0;">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <div style="margin-bottom:44px;max-width:620px;">
      <h2 style="font-family:'Sora',sans-serif;font-weight:800;font-size:clamp(28px,3.4vw,42px);letter-spacing:-.02em;margin:0 0 12px;">Packages for every event</h2>
      <p style="color:#9b9ba2;margin:0;font-size:15px;line-height:1.55;">Ready-made setups, adapted to your occasion.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;" class="pkg-grid">
      <div class="pkg-card">
        <div style="font-family:'Sora',sans-serif;font-weight:700;font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:#ff5a1f;">Wedding</div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:800;font-size:24px;margin:10px 0 12px;">The Wedding</h3>
        <p style="color:#a6a6ad;font-size:15px;line-height:1.6;margin:0 0 24px;">Ceremony and party sound, wireless mics and warm lighting.</p>
        <a href="#contact" class="btn btn-outline" style="padding:11px 18px;font-size:14px;border-radius:10px;">Request package</a>
      </div>
      <div class="pkg-card">
        <div style="font-family:'Sora',sans-serif;font-weight:700;font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:#ff5a1f;">Concert</div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:800;font-size:24px;margin:10px 0 12px;">The Concert</h3>
        <p style="color:#a6a6ad;font-size:15px;line-height:1.6;margin:0 0 24px;">Full stage PA, monitors, backline and a mixing console.</p>
        <a href="#contact" class="btn btn-outline" style="padding:11px 18px;font-size:14px;border-radius:10px;">Request package</a>
      </div>
      <div class="pkg-card">
        <div style="font-family:'Sora',sans-serif;font-weight:700;font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:#ff5a1f;">Corporate</div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:800;font-size:24px;margin:10px 0 12px;">The Corporate</h3>
        <p style="color:#a6a6ad;font-size:15px;line-height:1.6;margin:0 0 24px;">Conference audio, podium mics, screens and clean setup.</p>
        <a href="#contact" class="btn btn-outline" style="padding:11px 18px;font-size:14px;border-radius:10px;">Request package</a>
      </div>
    </div>
  </div>
</section>

<!-- Why us -->
<section id="why" class="section-alt" style="padding:88px 0;">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <div style="margin-bottom:44px;max-width:620px;">
      <h2 style="font-family:'Sora',sans-serif;font-weight:800;font-size:clamp(28px,3.4vw,42px);letter-spacing:-.02em;margin:0 0 12px;">Why Dali Sound</h2>
      <p style="color:#9b9ba2;margin:0;font-size:15px;line-height:1.55;">Four reasons clients keep coming back.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;" class="why-grid">
      <div class="why-card">
        <div style="width:14px;height:14px;background:#ff5a1f;transform:rotate(45deg);border-radius:3px;margin-bottom:18px;"></div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:17px;margin:0 0 8px;">Pro-grade gear</h3>
        <p style="color:#9b9ba2;font-size:14px;line-height:1.55;margin:0;">Maintained, road-ready equipment from trusted brands like RCF.</p>
      </div>
      <div class="why-card">
        <div style="width:14px;height:14px;background:#ff5a1f;transform:rotate(45deg);border-radius:3px;margin-bottom:18px;"></div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:17px;margin:0 0 8px;">Delivery &amp; setup</h3>
        <p style="color:#9b9ba2;font-size:14px;line-height:1.55;margin:0;">We bring it, install it and tune it — you do not lift a thing.</p>
      </div>
      <div class="why-card">
        <div style="width:14px;height:14px;background:#ff5a1f;transform:rotate(45deg);border-radius:3px;margin-bottom:18px;"></div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:17px;margin:0 0 8px;">On-site support</h3>
        <p style="color:#9b9ba2;font-size:14px;line-height:1.55;margin:0;">A technician stays on call throughout your event.</p>
      </div>
      <div class="why-card">
        <div style="width:14px;height:14px;background:#ff5a1f;transform:rotate(45deg);border-radius:3px;margin-bottom:18px;"></div>
        <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:17px;margin:0 0 8px;">Across the region</h3>
        <p style="color:#9b9ba2;font-size:14px;line-height:1.55;margin:0;">We serve events in many countries and languages.</p>
      </div>
    </div>
  </div>
</section>

<!-- Gallery -->
<section id="gallery" style="padding:88px 0;">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <div style="margin-bottom:42px;max-width:620px;">
      <h2 style="font-family:'Sora',sans-serif;font-weight:800;font-size:clamp(28px,3.4vw,42px);letter-spacing:-.02em;margin:0 0 12px;">From our past events</h2>
      <p style="color:#9b9ba2;margin:0;font-size:15px;line-height:1.55;">A glimpse of the stages we have powered.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px;">
      {% set galleryItems = ["Wedding reception","Open-air concert","Corporate gala","Club night","Festival stage","Private party"] %}
      {% for item in galleryItems %}
      <div class="gallery-item">
        <div class="gal-overlay"></div>
        <span style="position:absolute;top:12px;left:12px;font-size:11px;letter-spacing:.08em;color:#6f6f76;">[ photo ]</span>
        <span style="position:absolute;bottom:14px;left:14px;font-family:'Sora',sans-serif;font-weight:600;font-size:15px;color:#fff;">{{ item }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="section-alt" style="padding:88px 0;">
  <div style="max-width:860px;margin:0 auto;padding:0 24px;">
    <div style="margin-bottom:38px;">
      <h2 style="font-family:'Sora',sans-serif;font-weight:800;font-size:clamp(28px,3.4vw,42px);letter-spacing:-.02em;margin:0 0 12px;">Frequently asked questions</h2>
      <p style="color:#9b9ba2;margin:0;font-size:15px;line-height:1.55;">Everything you need to know before you book.</p>
    </div>
    <div class="faq-wrap">
      <details>
        <summary>How far in advance should I book? <i class="faq-icon">+</i></summary>
        <p class="faq-answer">As early as possible, especially in peak season — but we will always try to help with last-minute requests.</p>
      </details>
      <details>
        <summary>Do you deliver and set up? <i class="faq-icon">+</i></summary>
        <p class="faq-answer">Yes. Delivery, installation, tuning and pack-down are all part of our service.</p>
      </details>
      <details>
        <summary>Which areas do you cover? <i class="faq-icon">+</i></summary>
        <p class="faq-answer">We operate across the region and travel for larger events — just ask.</p>
      </details>
      <details>
        <summary>Can I rent a single item? <i class="faq-icon">+</i></summary>
        <p class="faq-answer">Absolutely — from one microphone to a full stage, we rent at any scale.</p>
      </details>
      <details>
        <summary>What if something fails during the event? <i class="faq-icon">+</i></summary>
        <p class="faq-answer">A technician is on standby and we carry backup gear to keep your show running.</p>
      </details>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" style="padding:88px 0;">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:start;" class="contact-grid">
    <div>
      <h2 style="font-family:'Sora',sans-serif;font-weight:800;font-size:clamp(28px,3.4vw,42px);letter-spacing:-.02em;margin:0 0 14px;">Tell us what you need</h2>
      <p style="color:#a6a6ad;font-size:16px;line-height:1.6;margin:0 0 32px;max-width:440px;">Describe your event and we will put together the perfect setup.</p>
      <div style="display:flex;flex-direction:column;gap:18px;">
        <div style="display:flex;align-items:center;gap:14px;">
          <div style="width:38px;height:38px;border-radius:10px;background:rgba(255,90,31,.14);display:flex;align-items:center;justify-content:center;flex:0 0 auto;">
            <div style="width:13px;height:13px;border:2px solid #ff5a1f;border-radius:50%;"></div>
          </div>
          <div>
            <div style="font-size:12px;color:#86868d;letter-spacing:.06em;text-transform:uppercase;">Call us</div>
            <div style="font-family:'Sora',sans-serif;font-weight:600;font-size:16px;">{{ site.phone }}</div>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:14px;">
          <div style="width:38px;height:38px;border-radius:10px;background:rgba(255,90,31,.14);display:flex;align-items:center;justify-content:center;flex:0 0 auto;">
            <div style="width:14px;height:11px;border:2px solid #ff5a1f;border-radius:3px;"></div>
          </div>
          <div>
            <div style="font-size:12px;color:#86868d;letter-spacing:.06em;text-transform:uppercase;">Email us</div>
            <div style="font-family:'Sora',sans-serif;font-weight:600;font-size:16px;">{{ site.email }}</div>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:14px;">
          <div style="width:38px;height:38px;border-radius:10px;background:rgba(255,90,31,.14);display:flex;align-items:center;justify-content:center;flex:0 0 auto;">
            <div style="width:11px;height:11px;background:#ff5a1f;transform:rotate(45deg);border-radius:2px;"></div>
          </div>
          <div>
            <div style="font-size:12px;color:#86868d;letter-spacing:.06em;text-transform:uppercase;">Based in</div>
            <div style="font-family:'Sora',sans-serif;font-weight:600;font-size:16px;">{{ site.city }}</div>
          </div>
        </div>
      </div>
    </div>
    <form action="#" method="post" style="background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.09);border-radius:20px;padding:28px;">
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div>
          <label style="display:block;font-size:13px;color:#9b9ba2;margin-bottom:7px;font-weight:500;">Your name</label>
          <input type="text" name="name" class="form-input" required>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div>
            <label style="display:block;font-size:13px;color:#9b9ba2;margin-bottom:7px;font-weight:500;">Email</label>
            <input type="email" name="email" class="form-input" required>
          </div>
          <div>
            <label style="display:block;font-size:13px;color:#9b9ba2;margin-bottom:7px;font-weight:500;">Event date</label>
            <input type="date" name="date" class="form-input" style="color-scheme:dark;">
          </div>
        </div>
        <div>
          <label style="display:block;font-size:13px;color:#9b9ba2;margin-bottom:7px;font-weight:500;">Event type</label>
          <select name="type" class="form-input">
            <option>Wedding</option>
            <option>Concert</option>
            <option>Corporate</option>
            <option>Private party</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label style="display:block;font-size:13px;color:#9b9ba2;margin-bottom:7px;font-weight:500;">What do you need?</label>
          <textarea name="message" rows="4" class="form-input" style="resize:vertical;"></textarea>
        </div>
        <button type="submit" class="btn btn-accent" style="width:100%;padding:15px;font-size:16px;border:none;">Send request</button>
      </div>
    </form>
  </div>
</section>

{% endblock %}
